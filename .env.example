# Spotify Developer credentials
# Create an app at https://developer.spotify.com/dashboard, then paste the
# Client ID / Secret here. The redirect URI must match what you registered
# in the Spotify app settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Logging
LOG_LEVEL=info

# Integration tests — leave unset on CI and for unit-test-only runs.
# Set RADIOFY_INTEGRATION=1 to enable tests that hit the real Spotify API.
RADIOFY_INTEGRATION=
# Name of the playlist the integration tests are allowed to read/write.
# Create it in Spotify first; the tests refuse to run if it doesn't exist.
RADIOFY_INTEGRATION_PLAYLIST=
