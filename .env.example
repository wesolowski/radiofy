# Spotify Developer credentials
# Create an app at https://developer.spotify.com/dashboard, then paste the
# Client ID / Secret here. The redirect URI must match what you registered
# in the Spotify app settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Logging
LOG_LEVEL=info
